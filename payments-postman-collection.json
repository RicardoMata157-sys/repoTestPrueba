{
  "info": {
    "name": "Payments App API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": {"raw": "http://localhost:8080/api/auth/register", "host": ["http://localhost:8080"], "path": ["api", "auth", "register"]},
        "body": {"mode": "raw", "raw": "{\n  \"fullName\": \"Ricardo Mata\",\n  \"email\": \"ricardo@example.com\",\n  \"password\": \"Password123\"\n}"}
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": {"raw": "http://localhost:8080/api/auth/login", "host": ["http://localhost:8080"], "path": ["api", "auth", "login"]},
        "body": {"mode": "raw", "raw": "{\n  \"email\": \"ricardo@example.com\",\n  \"password\": \"Password123\"\n}"}
      }
    },
    {
      "name": "Process Payment",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {"raw": "http://localhost:8080/api/transactions/process", "host": ["http://localhost:8080"], "path": ["api", "transactions", "process"]},
        "body": {"mode": "raw", "raw": "{\n  \"cardHolderName\": \"Ricardo Mata\",\n  \"cardNumber\": \"4111111111111112\",\n  \"expiry\": \"12/30\",\n  \"cvv\": \"123\",\n  \"amount\": 250.00,\n  \"currency\": \"MXN\",\n  \"userId\": 1\n}"}
      }
    }
  ]
}
